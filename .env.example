# Starburst Galaxy MCP
# Account name (e.g. philtrail1-bustbankdemo) → https://<account>.mcp.galaxy.starburst.io
STARBURST_ACCOUNT=your-account-name

# Or use full MCP URL (for Trino-style /mcp endpoint):
# STARBURST_MCP_URL=https://your-cluster.trino.galaxy.starburst.io

# Basic auth (Galaxy email + password, or service account)
STARBURST_USER=your-email@example.com
STARBURST_PASSWORD=your-password

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
